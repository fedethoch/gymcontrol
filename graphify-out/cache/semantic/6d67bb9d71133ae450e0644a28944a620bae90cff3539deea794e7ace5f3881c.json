{"nodes": [{"id": "next_best_practices_parallel_routes_parallel_intercepting_routes", "label": "Parallel & Intercepting Routes Guide", "file_type": "document", "source_file": ".codex/skills/next-best-practices/parallel-routes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "next_best_practices_parallel_routes_router_back_pattern", "label": "router.back() Modal Close Pattern", "file_type": "rationale", "source_file": ".codex/skills/next-best-practices/parallel-routes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Modals implemented via intercepting routes must be closed with router.back(), not router.push() or <Link>, because push/Link add new history entries, don't clear the intercepted route, and can cause the modal to flash or persist; back() removes the intercepted route from history and properly unmounts the modal."}, {"id": "next_best_practices_parallel_routes_default_tsx_requirement", "label": "default.tsx Requirement for Parallel Slots", "file_type": "rationale", "source_file": ".codex/skills/next-best-practices/parallel-routes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every parallel route slot (e.g. @modal) must have a default.tsx returning null; without it, refreshing any page 404s because Next.js cannot determine what to render in that slot."}], "edges": [{"source": "next_best_practices_parallel_routes_parallel_intercepting_routes", "target": "next_best_practices_parallel_routes_router_back_pattern", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".codex/skills/next-best-practices/parallel-routes.md", "source_location": null, "weight": 1.0}, {"source": "next_best_practices_parallel_routes_parallel_intercepting_routes", "target": "next_best_practices_parallel_routes_default_tsx_requirement", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".codex/skills/next-best-practices/parallel-routes.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "hyperedge_modal_intercepting_route_pattern", "label": "Modal pattern via parallel + intercepting routes", "nodes": ["next_best_practices_parallel_routes_parallel_intercepting_routes", "next_best_practices_parallel_routes_router_back_pattern", "next_best_practices_parallel_routes_default_tsx_requirement"], "relation": "implement", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".codex/skills/next-best-practices/parallel-routes.md"}]}